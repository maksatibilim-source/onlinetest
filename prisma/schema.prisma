// ─────────────────────────────────────────────────────────────
//  Online Test — Prisma схемасы
//  Дерекқор: PostgreSQL (Railway-дің басқарылатын Postgres сервисі).
//  Дерек код деплойларынан бөлек, тұрақты сақталады.
//  Локал дамыту үшін .env ішіндегі DATABASE_URL-ды локал не Railway
//  Postgres жолына қойыңыз.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Админ пайдаланушысы (админ панельге кіру үшін)
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("admin") // "admin"
  createdAt    DateTime @default(now())
}

// Тест тапсырушы оқушы (анкета деректері)
model Student {
  id        String        @id @default(cuid())
  fullName  String
  grade     Int // 5 | 6 | 7 | 8 | 9
  createdAt DateTime      @default(now())
  attempts  Attempt[]
  codes     OneTimeCode[]
}

// Пән — нақты бір сыныпқа бекітіледі (мыс. 5-сынып Математика)
model Subject {
  id        String     @id @default(cuid())
  name      String
  grade     Int // осы пән қай сыныпқа арналған
  createdAt DateTime   @default(now())
  questions Question[]
  attempts  Attempt[]

  @@unique([name, grade]) // бір сыныпта бір пән атауы қайталанбайды
}

// Сұрақ — 4 нұсқа + дұрыс жауап кілті. Мәтінде LaTeX болуы мүмкін.
model Question {
  id         String   @id @default(cuid())
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  text       String // Markdown + LaTeX ($...$ немесе $$...$$)
  imageUrl   String? // міндетті емес сурет
  optionA    String
  optionB    String
  optionC    String
  optionD    String
  correctKey String // "A" | "B" | "C" | "D"
  createdAt  DateTime @default(now())
  answers    Answer[]
}

// Тест сеансы — бір оқушының БІР ПӘН бойынша тапсыруы.
// Әр пән бөлек Attempt құрайды (оқушы пәндерді жеке-жеке тапсырады).
model Attempt {
  id             String       @id @default(cuid())
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  codeId         String?
  code           OneTimeCode? @relation(fields: [codeId], references: [id], onDelete: SetNull)
  questionIds    String[]     @default([]) // осы әрекетке таңдалған сұрақтар (макс 20), тұрақты болу үшін
  score          Int          @default(0) // дұрыс жауап саны
  totalQuestions Int          @default(0)
  violations     Int          @default(0) // прокторинг: ереже бұзу саны
  status         String       @default("in_progress") // "in_progress" | "finished"
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?
  answers        Answer[]

  @@unique([studentId, subjectId]) // бір оқушы бір пәнді бір рет қана тапсырады
}

// Жеке жауап — қай сұраққа не таңдалды. Пән бойынша ұпай осыдан жиналады.
model Answer {
  id          String   @id @default(cuid())
  attemptId   String
  attempt     Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedKey String? // "A"|"B"|"C"|"D" немесе null (жауапсыз)
  isCorrect   Boolean  @default(false)

  @@unique([attemptId, questionId])
}

// Бір реттік құпия сөз (4 таңбалы). Тест аяқталғанда жарамсыз болады.
model OneTimeCode {
  id        String    @id @default(cuid())
  code      String    @unique
  status    String    @default("active") // "active" | "used" | "revoked"
  grade     Int? // қосымша: кодты сыныпқа байлау (міндетті емес)
  studentId String?
  student   Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  attempts  Attempt[]
}
