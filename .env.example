# ── Дерекқор (PostgreSQL) ──────────────────────────────────
# Railway-де: Postgres сервисін қосқанда автоматты берілетін
# ${{ Postgres.DATABASE_URL }} айнымалысын қолданыңыз (төмендегі
# нұсқаулықты қараңыз). Локал дамыту үшін өз Postgres жолыңыз:
DATABASE_URL="postgresql://user:password@localhost:5432/onlinetest?schema=public"

# ── Cookie сессиясының кілті (МІНДЕТТІ түрде өзгертіңіз) ─────
# Ұзын кездейсоқ жол. Мысалы: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-secret-string"

# ── Бастапқы админ (алғашқы деплойда бір рет құрылады) ──────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-strong-password"
